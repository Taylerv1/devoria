rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // Helper functions
    // =========================================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && userRole() == 'admin';
    }

    function isEditor() {
      return isAuthenticated() && userRole() in ['admin', 'editor'];
    }

    function isBlogManager() {
      return isAuthenticated() && userRole() in ['admin', 'blog_manager'];
    }

    // =========================================================================
    // users/{uid}
    // Admins can read all users. Others can only read their own profile.
    // No client writes - use Firebase Admin SDK only.
    // =========================================================================
    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAdmin());
      allow write: if false;
    }

    // =========================================================================
    // messages
    // Client writes are blocked. Public forms submit through the server API.
    // Editors and above can read or manage messages.
    // =========================================================================
    match /messages/{messageId} {
      allow create: if false;
      allow read, delete, update: if isEditor();
    }

    // =========================================================================
    // projects
    // Public read. Editors and above can write.
    // =========================================================================
    match /projects/{docId} {
      allow read: if true;
      allow create, update, delete: if isEditor();
    }

    // =========================================================================
    // services
    // Public read. Editors and above can write.
    // =========================================================================
    match /services/{docId} {
      allow read: if true;
      allow create, update, delete: if isEditor();
    }

    // =========================================================================
    // blog
    // Public read. Blog managers and admins can write.
    // =========================================================================
    match /blog/{docId} {
      allow read: if true;
      allow create, update, delete: if isBlogManager();
    }

    // =========================================================================
    // news
    // Public read. Blog managers and admins can write.
    // =========================================================================
    match /news/{docId} {
      allow read: if true;
      allow create, update, delete: if isBlogManager();
    }

    // =========================================================================
    // Default deny - anything not explicitly allowed above is blocked.
    // =========================================================================
    match /{document=**} {
      allow read, write: if false;
    }

  }
}

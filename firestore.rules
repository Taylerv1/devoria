rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRole() {
      return isAuthenticated() ? currentUserDoc().role : null;
    }

    function isAdmin() {
      return isAuthenticated() && userRole() == 'admin';
    }

    function hasEditorPermission(resource, action) {
      return userRole() == 'editor' && (
        (resource == 'dashboard' && action == 'read') ||
        (resource == 'content' && (action == 'read' || action == 'update')) ||
        (resource == 'projects' && (action == 'read' || action == 'create' || action == 'update' || action == 'delete')) ||
        (resource == 'services' && (action == 'read' || action == 'create' || action == 'update' || action == 'delete')) ||
        (resource == 'messages' && (action == 'read' || action == 'update' || action == 'delete'))
      );
    }

    function hasBlogManagerPermission(resource, action) {
      return userRole() == 'blog_manager' && (
        (resource == 'blog' && (action == 'read' || action == 'create' || action == 'update' || action == 'delete')) ||
        (resource == 'news' && (action == 'read' || action == 'create' || action == 'update' || action == 'delete'))
      );
    }

    function hasBuiltInPermission(resource, action) {
      return isAdmin() || hasEditorPermission(resource, action) || hasBlogManagerPermission(resource, action);
    }

    function customRolePermissions() {
      return get(/databases/$(database)/documents/roles/$(userRole())).data.permissions;
    }

    function hasCustomPermission(resource, action) {
      return isAuthenticated() &&
        userRole() != null &&
        !hasBuiltInPermission(resource, action) &&
        exists(/databases/$(database)/documents/roles/$(userRole())) &&
        customRolePermissions()[resource] != null &&
        customRolePermissions()[resource][action] == true;
    }

    function hasPermission(resource, action) {
      return isAuthenticated() && (hasBuiltInPermission(resource, action) || hasCustomPermission(resource, action));
    }

    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAdmin());
      allow write: if false;
    }

    match /roles/{roleId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow create: if false;
      allow read: if hasPermission('messages', 'read');
      allow update: if hasPermission('messages', 'update');
      allow delete: if hasPermission('messages', 'delete');
    }

    match /projects/{docId} {
      allow read: if true;
      allow create: if hasPermission('projects', 'create');
      allow update: if hasPermission('projects', 'update');
      allow delete: if hasPermission('projects', 'delete');
    }

    match /services/{docId} {
      allow read: if true;
      allow create: if hasPermission('services', 'create');
      allow update: if hasPermission('services', 'update');
      allow delete: if hasPermission('services', 'delete');
    }

    match /site_content/{docId} {
      allow read: if true;
      allow create, update, delete: if hasPermission('content', 'update');
    }

    match /blog/{docId} {
      allow read: if true;
      allow create: if hasPermission('blog', 'create');
      allow update: if hasPermission('blog', 'update');
      allow delete: if hasPermission('blog', 'delete');
    }

    match /news/{docId} {
      allow read: if true;
      allow create: if hasPermission('news', 'create');
      allow update: if hasPermission('news', 'update');
      allow delete: if hasPermission('news', 'delete');
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
